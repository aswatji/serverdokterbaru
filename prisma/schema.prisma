generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  fullname      String
  photo         String?
  profession    String?
  updatedAt     DateTime       @updatedAt
  pushToken     String?
  chats         Chat[]         @relation("UserChats")
  unreads       ChatUnread[]   @relation("UserToUnread")
  ratings       DoctorRating[]
  payments      Payment[]
  prescriptions Prescription[] @relation("UserPrescriptions")
  appointments   Appointment[]   @relation("UserAppointments")
}

model Doctor {
  id               String           @id @default(cuid())
  bio              String?
  photo            String?
  about            String?           @db.Text
  experienceYears  Int?
  price            Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  fullname         String
  category         String
  university       String
  strNumber        String           @unique
  gender           String
  email            String           @unique
  password         String
  alamatRumahSakit String?
  pushToken        String?
  chats            Chat[]           @relation("DoctorChats")
  chatTemplates    ChatTemplate[]
  unreads          ChatUnread[]     @relation("DoctorToUnread")
  ratings          DoctorRating[]
  schedules        DoctorSchedule[]
  payments         Payment[]
  isAvailable      Boolean          @default(false)
  prescriptions    Prescription[]   @relation("DoctorPrescriptions")
  appointments      Appointment[]   @relation("DoctorAppointments")
}

model DoctorSchedule {
  id        String  @id @default(cuid())
  doctorId  String
  startTime String
  endTime   String
  day       String
  isActive  Boolean @default(true)
  doctor    Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointments     Appointment[]

  @@index([doctorId, day])
}

model Payment {
  id        String    @id @default(cuid())
  amount    Float
  status    String
  createdAt DateTime  @default(now())
  userId    String
  doctorId  String
  expiresAt DateTime?
  paidAt    DateTime?
  chat      Chat?
  doctor    Doctor    @relation(fields: [doctorId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

model Chat {
  id            String         @id @default(cuid())
  chatKey       String         @unique
  createdAt     DateTime       @default(now())
  doctorId      String
  userId        String
  lastMessageId String?        @unique
  paymentId     String?        @unique
  updatedAt     DateTime       @default(now()) @updatedAt
  expiredAt     DateTime?
  isActive      Boolean        @default(false)
  status        String         @default("open")
  doctor        Doctor         @relation("DoctorChats", fields: [doctorId], references: [id])
  lastMessage   ChatMessage?   @relation("LastMessageRelation", fields: [lastMessageId], references: [id])
  payment       Payment?       @relation(fields: [paymentId], references: [id])
  user          User           @relation("UserChats", fields: [userId], references: [id])
  dates         ChatDate[]
  unreads       ChatUnread[]   @relation("ChatToUnread")
  prescriptions Prescription[]

  @@unique([userId, doctorId])
  @@index([userId])
  @@index([doctorId])
  @@index([updatedAt])
}

model ChatDate {
  id        String        @id @default(cuid())
  chatId    String
  date      DateTime
  createdAt DateTime      @default(now())
  chat      Chat          @relation(fields: [chatId], references: [id])
  messages  ChatMessage[]

  @@unique([chatId, date])
  @@index([chatId])
  @@index([date])
}

model ChatMessage {
  id              String        @id @default(cuid())
  chatDateId      String
  sender          String
  content         String
  sentAt          DateTime      @default(now())
  type            String        @default("text")
  isRead          Boolean       @default(false)
  replyToId       String?
  fileUrl         String?
  chatLastMessage Chat?         @relation("LastMessageRelation")
  chatDate        ChatDate      @relation(fields: [chatDateId], references: [id])
  replyTo         ChatMessage?  @relation("ReplyRelation", fields: [replyToId], references: [id])
  replies         ChatMessage[] @relation("ReplyRelation")

  @@index([chatDateId])
  @@index([sentAt])
}

model News {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  image     String?
}

model Category {
  id    String  @id @default(cuid())
  name  String
  items String?
}

model CategoryDoctor {
  id       Int    @id @default(autoincrement())
  category String
}

model DoctorRating {
  id        String   @id @default(cuid())
  doctorId  String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor    Doctor   @relation(fields: [doctorId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([doctorId, userId])
}

model ChatUnread {
  id          String  @id @default(cuid())
  chatId      String
  userId      String?
  doctorId    String?
  unreadCount Int     @default(0)
  chat        Chat    @relation("ChatToUnread", fields: [chatId], references: [id])
  doctor      Doctor? @relation("DoctorToUnread", fields: [doctorId], references: [id])
  user        User?   @relation("UserToUnread", fields: [userId], references: [id])

  @@unique([chatId, userId])
  @@unique([chatId, doctorId])
  @@index([userId])
  @@index([doctorId])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  image         String?
  isRecommended Boolean  @default(false)
  viewCount     Int      @default(0)
}

model ChatTemplate {
  id        String   @id @default(cuid())
  category  String
  title     String
  content   String
  doctorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doctor    Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, category, title])
  @@index([doctorId])
  @@index([category])
}

model Prescription {
  id               String    @id @default(cuid())
  prescriptionCode String    @unique
  doctorId         String
  userId           String
  chatId           String?
  fileUrl          String
  status           String    @default("AVAILABLE")
  redeemedAt       DateTime?
  medicines        Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  chat             Chat?     @relation(fields: [chatId], references: [id])
  doctor           Doctor    @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  user             User      @relation("UserPrescriptions", fields: [userId], references: [id])

  @@index([prescriptionCode])
  @@index([doctorId])
  @@index([userId])
}

model Appointment {
  id          String   @id @default(cuid())
  userId      String
  doctorId    String
  scheduleId  String?  
  date        DateTime 
  time        String   
  appointmentId String?
  type        String   @default("CHAT") // "VIDEO", "CHAT", "OFFLINE"
  price       Int      @default(0)       // Menyimpan harga saat booking
  status      String   @default("PENDING") // PENDING, UPCOMING, COMPLETED, CANCELLED
  notes       String?  @db.Text 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User            @relation("UserAppointments", fields: [userId], references: [id])
  doctor      Doctor          @relation("DoctorAppointments", fields: [doctorId], references: [id])
  schedule    DoctorSchedule? @relation(fields: [scheduleId], references: [id])
  payments    Payment[]

  @@index([userId])
  @@index([doctorId])
  @@index([date])
}